# GO-KART OFFICIAL CODE
# The code that I made before was inccorrect becuase I assumed that I would use the PDH to control the motor,
#  but after deeper reaserach I found that using a PDH would allow me to nly use a Brushed motor.
#This was a big issue becuase brushed motors are very slow and don't work well in fast machines.
#This code simply makes the HUD, has offline GPS, and also reads the data from the pedal and sends it to the ESC to control the speed of the go-kart.
# I also had to revise the code to use a hall sensor instead of a potentiometer becuase the potentiometer was not working well with the hall sensor.
# The code is not Working well in this environiment, but on the rasberry pi which can install online databases, 

import time
import serial
import pynmea2
import pygame
import spidev
from gpiozero import PWMOutputDevice

# --- CONFIGURATION & INITIALIZATION ---
# 1. Initialize SPI for the MCP3008 (Pedal Reader)
spi = spidev.SpiDev()
spi.open(0, 0)
spi.max_speed_hz = 1350000

# 2. Initialize PWM for the ESC (Pin GPIO 18)
esc = PWMOutputDevice(18, frequency=50)

# 3. Initialize Serial Port for GPS Module
# Note: If using USB, it's usually '/dev/ttyUSB0'. If using GPIO pins, it's '/dev/ttyS0'
try:
    gps_serial = serial.Serial('/dev/ttyUSB0', baudrate=9600, timeout=0.5)
except Exception as e:
    print(f"GPS connection failed: {e}. Running without GPS hardware.")
    gps_serial = None

# 4. Initialize Pygame HUD
pygame.init()
screen = pygame.display.set_mode((800, 480))
pygame.display.set_caption("Go-Kart Advanced HUD")
clock = pygame.time.Clock()

# Fonts and Colors
FONT_LARGE = pygame.font.Font(None, 120)
FONT_MED = pygame.font.Font(None, 50)
FONT_SMALL = pygame.font.Font(None, 30)
COLOR_BLACK = (10, 10, 10)
COLOR_WHITE = (240, 240, 240)
COLOR_GREEN = (0, 220, 100)
COLOR_RED = (250, 50, 50)

# Global GPS variables
gps_speed_mph = 0.0
gps_lat = "0.0000"
gps_lon = "0.0000"
has_gps_lock = False

# --- HELPER FUNCTIONS ---
def read_pedal(channel=0):
    adc = spi.xfer2([1, (8 + channel) << 4, 0])
    return ((adc[1] & 3) << 8) + adc[2]

def update_gps_data():
    """Reads incoming raw serial stream from the GPS module and extracts telemetry"""
    global gps_speed_mph, gps_lat, gps_lon, has_gps_lock
    if gps_serial and gps_serial.in_waiting > 0:
        try:
            line = gps_serial.readline().decode('ascii', errors='replace')
            # Look for Recommended Minimum Navigation Information (RMC) sentence
            if line.startswith('$GPRMC') or line.startswith('$GNRMC'):
                msg = pynmea2.parse(line)
                if msg.status == 'A':  # 'A' means active connection/lock
                    has_gps_lock = True
                    # msg.spd_over_grnd is in knots, convert to MPH
                    if msg.spd_over_grnd:
                        gps_speed_mph = float(msg.spd_over_grnd) * 1.15078
                    gps_lat = f"{msg.latitude:.4f}"
                    gps_lon = f"{msg.longitude:.4f}"
                else:
                    has_gps_lock = False
        except Exception:
            pass # Ignore malformed serial reads

# --- MAIN CONTROL LOOP ---
running = True
try:
    while running:
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                running = False

        # 1. Read GPS (Updates offline location and speed data)
        update_gps_data()

        # 2. Process Pedal and send throttle command to ESC
        raw_pedal = read_pedal(0)
        idle_val, max_val = 200, 900
        clamped_raw = max(idle_val, min(raw_pedal, max_val))
        throttle_pct = int(((clamped_raw - idle_val) / (max_val - idle_val)) * 100)

        esc_duty = 0.05 + (throttle_pct / 100.0) * 0.05
        esc.value = esc_duty

        # 3. DRAW THE HUD
        screen.fill(COLOR_BLACK)

        # Draw Real-Time Speedometer from GPS
        speed_text = FONT_LARGE.render(f"{int(gps_speed_mph)}", True, COLOR_WHITE)
        unit_text = FONT_MED.render("MPH", True, COLOR_WHITE)
        screen.blit(speed_text, (360, 120))
        screen.blit(unit_text, (370, 210))

        # Draw Throttle Progress Bar
        pygame.draw.rect(screen, (50, 50, 50), (100, 380, 600, 30))
        pygame.draw.rect(screen, COLOR_GREEN, (100, 380, int(6 * throttle_pct), 30))
        throttle_text = FONT_SMALL.render(f"Throttle: {throttle_pct}%", True, COLOR_WHITE)
        screen.blit(throttle_text, (100, 350))

        # Draw GPS Telemetry Coordinates at the bottom corner
        lock_status = "GPS LOCKED" if has_gps_lock else "SEARCHING FOR SATELLITES..."
        lock_color = COLOR_GREEN if has_gps_lock else COLOR_RED
        
        status_text = FONT_SMALL.render(lock_status, True, lock_color)
        coords_text = FONT_SMALL.render(f"Lat: {gps_lat} | Lon: {gps_lon}", True, COLOR_WHITE)
        
        screen.blit(status_text, (20, 20))
        screen.blit(coords_text, (20, 50))

        pygame.display.flip()
        clock.tick(30)

except KeyboardInterrupt:
    print("Shutting down safely...")

finally:
    esc.value = 0
    esc.close()
    spi.close()
    if gps_serial:
        gps_serial.close()
    pygame.quit()